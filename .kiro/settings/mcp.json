{
  "mcpServers": {
    "mongodb": {
      "command": "npx",
      "args": [
        "-y",
        "mongodb-mcp-server@latest",
        "--readOnly",
        "--disabledTools", "create_collection,drop_collection,drop_database,rename_collection,create_index,drop_index,insert_many,update_many,delete_many,mongodb_logs,collection_storage_size,db_stats,explain,export_query,search_knowledge,list_knowledge_sources"
      ],
      "env": {
        "MDB_MCP_CONNECTION_STRING": "mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority"
      },
      "disabled": false,
      "autoApprove": ["find", "aggregate", "count", "listDatabases", "listCollections"]
    },
    "elevenlabs": {
      "command": "uvx",
      "args": ["elevenlabs-mcp@latest"],
      "env": {
        "ELEVENLABS_API_KEY": "<your_elevenlabs_api_key_here>"
      },
      "disabled": false,
      "autoApprove": []
    }
  }
}
