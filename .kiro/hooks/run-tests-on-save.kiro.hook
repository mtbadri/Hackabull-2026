{
  "enabled": true,
  "name": "Run Brain Tests on Save",
  "description": "Runs the Brain test suite whenever a Python file in services/brain, shared, or tests/brain is saved",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "services/brain/**/*.py",
      "shared/**/*.py",
      "tests/brain/**/*.py"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "python -m pytest tests/brain/ -x -q 2>&1 | tail -20"
  }
}