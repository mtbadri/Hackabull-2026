{
  "enabled": true,
  "name": "Run Tests After Task Completion",
  "description": "Runs the full Brain test suite after each spec task is marked complete to catch regressions early",
  "version": "1",
  "when": {
    "type": "postTaskExecution"
  },
  "then": {
    "type": "runCommand",
    "command": "python -m pytest tests/brain/ -x -q 2>&1 | tail -30"
  }
}